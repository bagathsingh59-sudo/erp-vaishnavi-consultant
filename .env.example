# ============================================
# Vaishnavi Consultant ERP — Environment Config
# ============================================
# Copy this file to .env and fill in your actual values

# Flask Secret Key (change this to a random string in production)
SECRET_KEY=change-this-to-a-random-string

# Application URLs
APP_URL=http://localhost:5000
PRODUCTION_URL=https://your-production-domain.com

# Database — PostgreSQL (REQUIRED — app will not start without this)
DATABASE_URL=postgresql://username:password@host:5432/database_name

# ── Self-hosted JWT Authentication (replaces Clerk) ──────────────────────────
# JWT_SECRET signs the short-lived access tokens — set a long random string in
# production (e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`).
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ACCESS_TTL_MIN=30          # access-token lifetime, minutes
JWT_REFRESH_TTL_DAYS=14        # refresh-token lifetime, days
JWT_ISSUER=vaishnavi-erp
# Cookie security: leave unset to auto-detect HTTPS, or force with 1/0.
# JWT_COOKIE_SECURE=1
# JWT_COOKIE_SAMESITE=Lax

# Local-dev only: set to 1 to bypass login entirely (NEVER in production).
# AUTH_DEV_OPEN=0

# Internal service-to-service key (used by the Client Portal to call ERP report
# endpoints without logging in). Keep secret; must match the portal's value.
# INTERNAL_API_KEY=change-me

# ── Password Generator (Clerk → JWT credential migration) ────────────────────
# Set PASSWORD_GENERATOR=true to make the app run the credential migration on
# boot (like a seeder): it pulls every Clerk user, gives anyone without a
# password a TEMPORARY one (shown to the admin in Admin → Users), and forces
# them to change it on first login. Idempotent — only touches users with no
# password. Set it back to false once everyone has logged in, to stop the
# per-boot Clerk API calls. Needs CLERK_SECRET_KEY present to import users.
PASSWORD_GENERATOR=false
CLERK_SECRET_KEY=sk_test_XXXX
